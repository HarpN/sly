{
  "schema_version": "1.0.0",
  "project": {
    "name": "sly",
    "description": "PSN telemetry sync agent that forwards signed proposals to Judy",
    "default_branch": "main"
  },
  "runtime": {
    "primary_mode": "docker_compose",
    "grpc_port": 50055
  },
  "commands": {
    "start": {
      "shell": "powershell",
      "cwd": ".",
      "command": "docker compose up --build -d"
    },
    "stop": {
      "shell": "powershell",
      "cwd": ".",
      "command": "docker compose down"
    },
    "test": {
      "shell": "powershell",
      "cwd": ".",
      "command": "pytest"
    }
  },
  "entrypoint_files": [
    "README.md",
    "app/grpc_server.py",
    "app/psn_client.py",
    "app/judy_client.py",
    "app/config.py",
    "proto/sly.proto",
    "docker-compose.yml"
  ]
}